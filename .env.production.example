DJANGO_ENV=production
DEBUG=False
SECRET_KEY=replace-with-a-long-random-secret
ALLOWED_HOSTS=privora,www.privora
CORS_ALLOWED_ORIGINS=https://privora,https://www.privora
FRONTEND_URL=https://privora

DB_ENGINE=django.db.backends.postgresql
DB_NAME=privora
DB_USER=privora
DB_PASSWORD=replace-with-managed-db-password
DB_HOST=postgres
DB_PORT=5432

CACHE_URL=redis://redis:6379/1

EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend

DEFAULT_FROM_EMAIL=Privora Support <privora.support@gmail.com>
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=privora.support@gmail.com
EMAIL_HOST_PASSWORD=heli1106
EMAIL_USE_TLS=True
EMAIL_USE_SSL=False
EMAIL_TIMEOUT=10

USE_S3_STORAGE=True
AWS_ACCESS_KEY_ID=replace-with-object-storage-key
AWS_SECRET_ACCESS_KEY=replace-with-object-storage-secret
AWS_STORAGE_BUCKET_NAME=privora-files
AWS_S3_REGION_NAME=us-east-1
AWS_S3_ENDPOINT_URL=
AWS_S3_CUSTOM_DOMAIN=

SENTRY_DSN=
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.05

SECURE_SSL_REDIRECT=True
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True
SECURE_HSTS_SECONDS=31536000
SECURE_HSTS_INCLUDE_SUBDOMAINS=True
SECURE_HSTS_PRELOAD=True

MAX_FILE_SIZE=104857600
MAX_FILES_PER_USER=1000
LOCAL_MEDIA_ROOT=D:\PrivoraStorage
JWT_ACCESS_TOKEN_LIFETIME_HOURS=1
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7
GUNICORN_WORKERS=3
GUNICORN_TIMEOUT=60
